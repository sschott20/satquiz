{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "outDir": ".tsbuildinfo",
    "strict": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "svelte.config.js", "playwright.config.ts"]
}
